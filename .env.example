# ── DMV Login Info ────────────────────────────────────────────
DMV_LICENSE = your CA driver license or permit number, e.g. A1234567
DMV_DOB     = date of birth in MM/DD/YYYY format, e.g. 01/31/1990

# ── Location ──────────────────────────────────────────────────
DMV_ZIP    = your zip code, e.g. 95035
DMV_RADIUS = search radius in miles, e.g. 25

# ── Notification Contacts ─────────────────────────────────────
GMAIL_ADDRESS       = gmail you want to send notifications from, e.g. you@gmail.com
GMAIL_APP_PASSWORD  = 16-char app password from myaccount.google.com/apppasswords
NOTIFY_EMAIL        = email to receive notifications (can be same as GMAIL_ADDRESS)
NOTIFY_PHONE_DIGITS = your phone number digits only, no dashes or spaces, e.g. 4085551234
CARRIER             = your carrier SMS gateway (default: tmomail.net for T-Mobile)
                    # att=txt.att.net | verizon=vtext.com | cricket=sms.cricketwireless.net

# ── Service Type ──────────────────────────────────────────────
DMV_SERVICE_TYPE = automobile
                 # options: automobile | commercial | motorcycle | realid_cdl | knowledge

# ── Scheduling ────────────────────────────────────────────────
CHECK_INTERVAL_MINUTES = 5
MAX_SLOTS              = 3
NOTIFY_FREQUENCY       = realtime
                       # options: realtime | once_day | twice_day

# ── Appointment Filters (optional) ────────────────────────────
TIME_FILTER  = all
             # options: all | morning | afternoon | custom
TIME_FROM    = 00:00
TIME_TO      = 23:59

DAY_FILTER   = all
             # options: all | weekdays | custom
ALLOWED_DAYS = [0,1,2,3,4]
             # 0=Mon 1=Tue 2=Wed 3=Thu 4=Fri 5=Sat 6=Sun

WITHIN_DAYS  =
             # only notify for appointments within next N days, leave blank for no limit